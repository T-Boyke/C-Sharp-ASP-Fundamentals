@model IEnumerable<Unit_03_RSVP_App.Models.GuestResponse>

@{
    ViewData["Title"] = "Guest List";
}

<div class="max-w-4xl mx-auto">
    <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-extrabold text-slate-900 tracking-tight">
            <i class="fa-solid fa-clipboard-list mr-3 text-brand"></i> Confirmed Guests
        </h2>
        <span class="px-4 py-1 bg-brand/10 text-brand rounded-full text-sm font-bold shadow-sm border border-brand/5">
            <i class="fa-solid fa-user-check mr-1"></i> @Model.Count() Attending
        </span>
    </div>

    <div class="card">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="px-8 py-5 text-sm font-semibold text-slate-600 uppercase tracking-wider">Name</th>
                        <th class="px-8 py-5 text-sm font-semibold text-slate-600 uppercase tracking-wider">Email Address</th>
                        <th class="px-8 py-5 text-sm font-semibold text-slate-600 uppercase tracking-wider">Phone</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var r in Model)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-8 py-6 font-bold text-slate-800">@r.Name</td>
                            <td class="px-8 py-6 text-slate-500">@r.Email</td>
                            <td class="px-8 py-6 text-slate-500 font-mono text-sm">@r.Phone</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="px-8 py-12 text-center text-slate-400 italic">
                                No guests confirmed yet. Why not be the first?
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-8 text-center">
        @await Html.PartialAsync("Components/_Button", new { Text = "Add More RSVPs", IsPrimary = true, Icon = "fa-solid fa-plus" })
    </div>
</div>
