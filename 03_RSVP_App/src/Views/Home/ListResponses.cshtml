@model IEnumerable<Unit_03_RSVP_App.Models.GuestResponse>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Guest List";
}

<div class="container py-12">
    <div class="o-card s-card--primary shadow-xl">
        <div class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h2 class="text-3xl font-bold text-gray-800 s-text--hero mb-2">Confirmed Guests</h2>
                <p class="text-gray-500">Here is the list of people attending the party.</p>
            </div>
            <a class="o-btn s-btn--primary md:self-start" asp-action="Index">
                Back to Home
            </a>
        </div>

        <div class="overflow-x-auto rounded-xl border border-gray-100 shadow-inner bg-gray-50/30">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-800 text-white">
                        <th class="px-6 py-4 font-bold uppercase tracking-wider text-sm">Name</th>
                        <th class="px-6 py-4 font-bold uppercase tracking-wider text-sm">Email</th>
                        <th class="px-6 py-4 font-bold uppercase tracking-wider text-sm">Phone</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var r in Model)
                    {
                        <tr class="hover:bg-white transition-colors">
                            <td class="px-6 py-4 font-medium text-gray-900 border-l-4 border-transparent hover:border-brand-primary">@r.Name</td>
                            <td class="px-6 py-4 text-gray-600">@r.Email</td>
                            <td class="px-6 py-4 text-gray-600 font-mono text-sm">@r.Phone</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-12">
                <p class="text-gray-400 italic">No one has confirmed yet. Be the first!</p>
            </div>
        }
    </div>
</div>
