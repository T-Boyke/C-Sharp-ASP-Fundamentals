@model Unit_03_RSVP_App.Models.GuestResponse

@{
    ViewData["Title"] = "Thank You";
}

<div class="max-w-xl mx-auto text-center">
    <div class="card p-12">
        <div class="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center text-3xl mx-auto mb-8">
            <i class="fa-solid fa-check"></i>
        </div>
        <h1 class="text-4xl font-bold text-slate-900 mb-4">Thank you, @Model.Name!</h1>
        
        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 mb-8">
            @if (Model.WillAttend == true)
            {
                <p class="text-lg text-slate-600">
                    It's great that you're coming! 🎈 <br/>
                    We've already saved a spot for you.
                </p>
            }
            else
            {
                <p class="text-lg text-slate-600">
                    Sorry to hear you can't make it, but we appreciate you letting us know.
                </p>
            }
        </div>

        <div class="flex flex-col gap-4">
            <a asp-action="ListResponses" class="btn btn-primary">
                <i class="fa-solid fa-users mr-2"></i> View Guest List
            </a>
            <a asp-action="Index" class="text-brand font-semibold hover:underline flex items-center justify-center gap-2">
                <i class="fa-solid fa-house"></i> Return to Home
            </a>
        </div>
    </div>
</div>
