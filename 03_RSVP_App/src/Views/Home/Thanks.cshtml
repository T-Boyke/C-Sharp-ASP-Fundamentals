@model Unit_03_RSVP_App.Models.GuestResponse

@{
    Layout = "_Layout";
    ViewData["Title"] = "Thank You";
}

<div class="container py-12 flex justify-center">
    <div class="o-card s-card--success w-full max-w-2xl text-center">
        <h1 class="s-text--hero text-4xl text-brand-success mb-6">
            Thank you, @Model.Name!
        </h1>
        
        <div class="rounded-2xl bg-emerald-50 p-8 mb-8 border border-emerald-100 italic text-xl text-emerald-900 shadow-inner">
            @if (Model.WillAttend == true)
            {
                <span class="drop-shadow-sm">It's great that you're coming! The drinks are already in the fridge! 🍹</span>
            }
            else
            {
                <span class="drop-shadow-sm">Sorry to hear you can't make it, but thanks for letting us know. ✉️</span>
            }
        </div>
        
        <p class="text-gray-600 mb-8">
            Want to see who else is joining the party?
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a class="o-btn s-btn--success" asp-action="ListResponses">
                View Guest List
            </a>
            <a class="o-btn border-2 border-gray-200 text-gray-600 hover:bg-gray-50" asp-action="Index">
                Back to Home
            </a>
        </div>
    </div>
</div>
