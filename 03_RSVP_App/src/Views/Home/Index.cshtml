<div class="max-w-4xl mx-auto text-center py-20">
    <div class="inline-block px-4 py-1.5 mb-6 text-sm font-bold tracking-widest text-blue-600 uppercase bg-blue-50 rounded-full border border-blue-100">
        You're Invited!
    </div>
    <h1 class="text-7xl font-black tracking-tighter text-slate-900 mb-8 leading-none">
        @ViewBag.Greeting!
    </h1>
    <p class="text-2xl text-slate-500 mb-16 max-w-2xl mx-auto leading-relaxed font-medium">
        We're throwing a celebration and your presence would make it truly special. 
        Please let us know if you'll be joining the party.
    </p>
    
    <div class="flex flex-col sm:flex-row justify-center items-center gap-8">
        <div class="animate-dance">
            <a asp-action="RsvpForm" class="btn btn-primary text-xl px-16 py-5 shadow-2xl">
                <i class="fa-solid fa-calendar-check mr-3"></i> RSVP Now
            </a>
        </div>
        <a asp-action="ListResponses" class="btn btn-secondary text-xl px-16 py-5">
            <i class="fa-solid fa-list-ul mr-3"></i> View Guest List
        </a>
    </div>
    
    <div class="mt-24 grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div class="card p-8 group hover:border-brand/30 transition-colors">
            <div class="text-brand text-4xl mb-4 group-hover:scale-110 transition-transform"><i class="fa-solid fa-location-dot"></i></div>
            <h3 class="font-bold mb-2 text-lg">Location</h3>
            <p class="text-slate-500 text-sm">BitLC Neuss</p>
        </div>
        <div class="card p-8 group hover:border-brand/30 transition-colors">
            <div class="text-brand text-4xl mb-4 group-hover:scale-110 transition-transform"><i class="fa-regular fa-clock"></i></div>
            <h3 class="font-bold mb-2 text-lg">When</h3>
            <p class="text-slate-500 text-sm">27.02.2026, 08:15</p>
        </div>
        <div class="card p-8 group hover:border-brand/30 transition-colors">
            <div class="text-brand text-4xl mb-4 group-hover:scale-110 transition-transform"><i class="fa-solid fa-utensils"></i></div>
            <h3 class="font-bold mb-2 text-lg">Food</h3>
            <p class="text-slate-500 text-sm">Drinks & Catering included</p>
        </div>
    </div>
</div>
