@model Unit_03_RSVP_App.Models.GuestResponse

@{
    ViewData["Title"] = "RSVP Form";
}

<div class="max-w-xl mx-auto">
    <div class="card">
        <div class="card-header">
            Confirm Your Attendance
        </div>
        <div class="card-body">
            <form asp-action="RsvpForm" method="post">
                <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 border border-red-100 text-red-600 rounded-xl text-sm"></div>

                @* SFC: Using Partial Views as Components *@
                @await Html.PartialAsync("Components/_FormControl", new { Label = "Your Name", Property = "Name", ErrorMessage = "We need your name!" })
                
                @await Html.PartialAsync("Components/_FormControl", new { Label = "Email Address", Property = "Email", Type = "email", ErrorMessage = "Please provide a valid email." })

                @await Html.PartialAsync("Components/_FormControl", new { Label = "Phone Number", Property = "Phone", Type = "tel", ErrorMessage = "A contact number is required." })

                @await Html.PartialAsync("Components/_FormControl", new { 
                    Label = "Will you attend?", 
                    Property = "WillAttend", 
                    Type = "select", 
                    ErrorMessage = "Tell us if you're coming!",
                    Options = new HtmlString(@"
                        <option value=''>Choose an option</option>
                        <option value='true'>Yes, count me in!</option>
                        <option value='false'>No, I can't make it</option>
                    ")
                })

                <div class="flex flex-col sm:flex-row gap-4 mt-8 pt-6 border-t border-slate-100">
                    @await Html.PartialAsync("Components/_Button", new { Text = "Submit RSVP", IsPrimary = true })
                    <a asp-action="Index" class="btn btn-secondary text-center">Back to Home</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
