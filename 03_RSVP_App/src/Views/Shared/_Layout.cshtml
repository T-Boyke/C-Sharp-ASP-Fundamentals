<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Unit_03_RSVP_App</title>
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <style type="text/tailwindcss">
        @theme {
            --color-brand-primary: #3b82f6;
            --color-brand-success: #10b981;
        }

        /* OOCSS: Structure Objects */
        .o-card {
            @apply rounded-xl p-8 overflow-hidden transition-all duration-300;
        }
        .o-field-group {
            @apply mb-6 flex flex-col gap-2;
        }
        .o-input {
            @apply w-full px-4 py-3 rounded-lg border-2 outline-none transition-colors;
        }
        .o-btn {
            @apply px-6 py-3 rounded-lg font-bold transition-all transform active:scale-95 cursor-pointer;
        }

        /* OOCSS: Skin Modifiers (Tailwind 4.1: text-shadow, drop-shadow) */
        .s-card--primary {
            @apply bg-white border-brand-primary/20 border shadow-2xl drop-shadow-brand-primary/20;
        }
        .s-card--success {
            @apply bg-white border-brand-success/20 border shadow-2xl drop-shadow-brand-success/20;
        }
        .s-input--standard {
            @apply border-gray-200 focus:border-brand-primary bg-gray-50/50;
        }
        .s-btn--primary {
            @apply bg-brand-primary text-white hover:bg-blue-600 shadow-lg text-shadow-sm;
        }
        .s-btn--success {
            @apply bg-brand-success text-white hover:bg-emerald-600 shadow-lg text-shadow-sm;
        }
        .s-text--hero {
            @apply text-shadow-lg font-black tracking-tight;
        }
    </style>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Unit_03_RSVP_App</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="RsvpForm">RSVP</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="ListResponses">Guest List</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Unit_03_RSVP_App - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
