<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RSVP Premium</title>
    <!-- Tailwind CSS 4 -->
    <script src="https://unpkg.com/@@tailwindcss/browser@@4"></script>
    <!-- Font Awesome 7 (Latest) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style type="text/css">
        @* OOCSS Base Objects & Skins *@
        @@theme {
            --color-brand: oklch(0.6 0.18 260);
            --color-brand-hover: oklch(0.5 0.18 260);
            
            --animate-dance: dance 3s ease-in-out infinite;

            @@keyframes dance {
                0%, 100% { transform: translateY(0) rotate(0); }
                20% { transform: translateY(-12px) rotate(-8deg) scale(1.05); }
                40% { transform: translateY(0) rotate(8deg) scale(0.95); }
                60% { transform: translateY(-6px) rotate(-4deg) scale(1.02); }
                80% { transform: translateY(0) rotate(4deg) scale(0.98); }
            }
        }

        @@layer components {
            .app-container { @@apply min-h-screen bg-slate-50 font-sans text-slate-900; }
            .card { @@apply bg-white rounded-2xl shadow-xl overflow-hidden border border-slate-100; }
            .card-header { @@apply bg-brand p-6 text-white text-xl font-bold; }
            .card-body { @@apply p-8; }
            .btn { @@apply px-6 py-3 rounded-lg font-semibold transition-all duration-200 inline-flex items-center justify-center; }
            .btn-primary { @@apply bg-brand text-white hover:bg-brand-hover hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-brand/20; }
            .btn-secondary { @@apply bg-slate-200 text-slate-700 hover:bg-slate-300; }
            .input-field { @@apply w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-4 focus:ring-brand/10 focus:border-brand outline-none transition-all; }
            .label-text { @@apply block text-sm font-medium text-slate-600 mb-2; }
        }
    </style>
</head>
<body class="app-container">
    <header>
        <nav class="bg-white border-b border-slate-100 shadow-sm sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between h-16 items-center">
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 bg-brand rounded-lg flex items-center justify-center text-white font-bold text-sm">RSVP</div>
                        <a class="text-xl font-bold tracking-tight text-slate-800" asp-area="" asp-controller="Home" asp-action="Index">Party Planner</a>
                    </div>
                    <div class="flex gap-6">
                        <a class="text-sm font-medium text-slate-600 hover:text-brand transition-colors" asp-action="Index">
                            <i class="fa-solid fa-house mr-1"></i> Home
                        </a>
                        <a class="text-sm font-medium text-slate-600 hover:text-brand transition-colors" asp-action="RsvpForm">
                            <i class="fa-solid fa-pen-to-square mr-1"></i> RSVP
                        </a>
                        <a class="text-sm font-medium text-slate-600 hover:text-brand transition-colors" asp-action="ListResponses">
                            <i class="fa-solid fa-users mr-1"></i> Guest List
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="animate-in fade-in duration-700">
            @RenderBody()
        </div>
    </main>

    <footer class="mt-auto border-t border-slate-100 py-8 text-center text-slate-400 text-sm">
        <div class="max-w-7xl mx-auto px-4">
            &copy; 2026 - Modern RSVP App - Driven by SOLID & Tailwind 4
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
