@{
    ViewData["Title"] = "Startseite";
}

<div class="hero-container animate-fade-in-up">
    
    <div class="space-y-4">
        <div class="hero-badge">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
            </span>
            C# ASP.NET Core Unit 04 Einkaufsliste
        </div>
        <h1 class="hero-title">
            Intelligente <span class="text-brand-600 drop-shadow-sm">Einkaufsliste</span>
        </h1>
        <p class="hero-subtitle">
            Verwalten Sie Ihre Einkäufe effizient, modern und übersichtlich aus verschiedenen Geschäften an einem zentralen Ort.
        </p>
    </div>

    <div class="hero-actions">
        <a asp-action="ArtikelForm" class="btn-primary">
            <svg class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Neuen Artikel hinzufügen
        </a>
        <a asp-action="ArtikelAnsehen" class="btn-secondary">
            <svg class="w-5 h-5 mr-2 group-hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
            Alle Artikel ansehen
        </a>
    </div>
</div>
