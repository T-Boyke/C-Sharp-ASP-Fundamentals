@{
    ViewData["Title"] = "Startseite";
}

<div class="max-w-3xl mx-auto flex flex-col items-center justify-center min-h-[60vh] text-center space-y-10 animate-fade-in-up">
    
    <div class="space-y-4">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-50 text-brand-700 text-sm font-semibold tracking-wide border border-brand-100 mb-4 shadow-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
            </span>
            C# ASP.NET Core Unit 04 Einkaufsliste
        </div>
        <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight text-gray-900">
            Intelligente <span class="text-brand-600 drop-shadow-sm">Einkaufsliste</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto font-medium">
            Verwalten Sie Ihre Einkäufe effizient, modern und übersichtlich aus verschiedenen Geschäften an einem zentralen Ort.
        </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto mt-8">
        <a asp-action="ArtikelForm" class="inline-flex items-center justify-center px-6 py-3 border border-transparent font-medium rounded-xl focus:outline-none focus:ring-2 focus:ring-offset-2 transition-all duration-300 cursor-pointer bg-brand-500 text-white hover:bg-brand-600 focus:ring-brand-500 hover:shadow-lg hover:-translate-y-0.5 group w-full sm:w-auto text-lg shadow-brand-500/25">
            <svg class="w-5 h-5 mr-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Neuen Artikel hinzufügen
        </a>
        <a asp-action="ArtikelAnsehen" class="inline-flex items-center justify-center px-6 py-3 border border-transparent font-medium rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 transition-all duration-300 cursor-pointer bg-white text-gray-700 border-gray-300 hover:bg-gray-50 focus:ring-brand-500 hover:shadow-md hover:-translate-y-0.5 group w-full sm:w-auto text-lg">
            <svg class="w-5 h-5 mr-2 group-hover:text-brand-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
            Alle Artikel ansehen
        </a>
    </div>
</div>
