@model _04_ShoppingList.Models.Position
@{
    ViewData["Title"] = "Neuen Artikel anlegen";
}

<div class="form-container animate-fade-in">
    <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Neuen Artikel hinzufügen</h1>
        <p class="mt-2 text-gray-500">Tragen Sie hier ein, was Sie benötigen und wo es gekauft werden soll.</p>
    </div>

    <!-- Atomic CSS Card Component -->
    <div class="card p-8">
        <form asp-action="ArtikelForm" method="post" class="space-y-6">
            
            <div class="input-group">
                <label asp-for="Name" class="label-standard">Artikelname</label>
                <div class="relative rounded-xl shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fa-solid fa-cart-shopping w-5 h-5 text-gray-400"></i>
                    </div>
                    <input asp-for="Name" class="input-field" placeholder="z.B. Vollmilch 3.5%" required />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="input-group">
                    <label asp-for="Anzahl" class="label-standard">Anzahl</label>
                    <div class="relative rounded-xl shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-hashtag w-5 h-5 text-gray-400"></i>
                        </div>
                        <input asp-for="Anzahl" type="number" min="1" value="1" class="input-field" required />
                    </div>
                </div>

                <div class="input-group">
                    <label asp-for="Geschaeft" class="label-standard">Geschäft</label>
                    <div class="relative rounded-xl shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-solid fa-store w-5 h-5 text-gray-400"></i>
                        </div>
                        <input asp-for="Geschaeft" class="input-field" placeholder="z.B. Edeka" required />
                    </div>
                </div>
            </div>

            <div class="pt-6 flex flex-col sm:flex-row gap-4 border-t border-gray-100">
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-floppy-disk w-5 h-5 mr-2 group-hover:-translate-y-1 transition-transform"></i>
                    Speichern
                </button>
                <a asp-action="Index" class="btn-secondary">
                    Zurück
                </a>
            </div>
        </form>
    </div>
</div>
