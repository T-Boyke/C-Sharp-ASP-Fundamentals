@model _04_ShoppingList.Models.Position
@{
    ViewData["Title"] = "Neuen Artikel anlegen";
}

<div class="form-container animate-fade-in">
    <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Neuen Artikel hinzufügen</h1>
        <p class="mt-2 text-gray-500">Tragen Sie hier ein, was Sie benötigen und wo es gekauft werden soll.</p>
    </div>

    <!-- Atomic CSS Card Component -->
    <div class="form-card">
        <form asp-action="ArtikelForm" method="post" class="space-y-6">
            
            <div class="input-group">
                <label asp-for="Name" class="label-standard">Artikelname</label>
                <div class="relative rounded-xl shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                    </div>
                    <input asp-for="Name" class="input-field" placeholder="z.B. Vollmilch 3.5%" required />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="input-group">
                    <label asp-for="Anzahl" class="label-standard">Anzahl</label>
                    <div class="relative rounded-xl shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" /></svg>
                        </div>
                        <input asp-for="Anzahl" type="number" min="1" value="1" class="input-field" required />
                    </div>
                </div>

                <div class="input-group">
                    <label asp-for="Geschaeft" class="label-standard">Geschäft</label>
                    <div class="relative rounded-xl shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                        </div>
                        <input asp-for="Geschaeft" class="input-field" placeholder="z.B. Edeka" required />
                    </div>
                </div>
            </div>

            <div class="pt-6 flex flex-col sm:flex-row gap-4 border-t border-gray-100">
                <button type="submit" class="btn-primary">
                    <svg class="w-5 h-5 mr-2 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                    Speichern
                </button>
                <a asp-action="Index" class="btn-secondary">
                    Zurück
                </a>
            </div>
        </form>
    </div>
</div>
