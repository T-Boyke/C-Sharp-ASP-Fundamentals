@model _04_ShoppingList.Models.Position
@{
    ViewData["Title"] = "Neuen Artikel anlegen";
}

<div class="max-w-2xl mx-auto animate-fade-in">
    <div class="mb-8">
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Neuen Artikel hinzufügen</h1>
        <p class="mt-2 text-gray-500">Tragen Sie hier ein, was Sie benötigen und wo es gekauft werden soll.</p>
    </div>

    <!-- Atomic CSS Card Component -->
    <div class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-xl border border-white/20 p-8">
        <form asp-action="ArtikelForm" method="post" class="space-y-6">
            
            <div class="space-y-1">
                <label asp-for="Name" class="block text-sm font-medium text-gray-700">Artikelname</label>
                <div class="relative rounded-xl shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                    </div>
                    <!-- Atomic input-field classes -->
                    <input asp-for="Name" class="mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-brand-500 focus:ring-brand-500 sm:text-sm px-4 py-3 bg-white/50 transition-all duration-200 outline-none pl-10" placeholder="z.B. Vollmilch 3.5%" required />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="space-y-1">
                    <label asp-for="Anzahl" class="block text-sm font-medium text-gray-700">Anzahl</label>
                    <div class="relative rounded-xl shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" /></svg>
                        </div>
                        <input asp-for="Anzahl" type="number" min="1" value="1" class="mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-brand-500 focus:ring-brand-500 sm:text-sm px-4 py-3 bg-white/50 transition-all duration-200 outline-none pl-10" required />
                    </div>
                </div>

                <div class="space-y-1">
                    <label asp-for="Geschaeft" class="block text-sm font-medium text-gray-700">Geschäft</label>
                    <div class="relative rounded-xl shadow-sm">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                        </div>
                        <input asp-for="Geschaeft" class="mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-brand-500 focus:ring-brand-500 sm:text-sm px-4 py-3 bg-white/50 transition-all duration-200 outline-none pl-10" placeholder="z.B. Edeka" required />
                    </div>
                </div>
            </div>

            <div class="pt-6 flex flex-col sm:flex-row gap-4 border-t border-gray-100">
                <button type="submit" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-xl focus:outline-none focus:ring-2 focus:ring-offset-2 transition-all duration-300 cursor-pointer bg-brand-500 text-white hover:bg-brand-600 focus:ring-brand-500 hover:shadow-lg hover:-translate-y-0.5 sm:flex-1 group">
                    <svg class="w-5 h-5 mr-2 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                    Speichern
                </button>
                <a asp-action="Index" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 transition-all duration-300 cursor-pointer bg-white text-gray-700 border-gray-300 hover:bg-gray-50 focus:ring-brand-500 hover:shadow-md hover:-translate-y-0.5 sm:w-1/3">
                    Zurück
                </a>
            </div>
        </form>
    </div>
</div>
