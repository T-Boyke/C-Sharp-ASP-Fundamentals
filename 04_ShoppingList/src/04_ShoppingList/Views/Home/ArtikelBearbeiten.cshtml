@model _04_ShoppingList.Models.Position
@{
    ViewData["Title"] = "Artikel bearbeiten";
}

<div class="form-container animate-fade-in-up">
    <!-- Header Area -->
    <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center p-4 bg-brand-100 rounded-2xl mb-4 shadow-inner">
            <fa-icon name="pen-to-square" class="text-3xl text-brand-600" />
        </div>
        <h1 class="hero-title">Artikel <span class="text-brand-600">bearbeiten</span></h1>
        <p class="hero-subtitle text-gray-500 mt-2">Passen Sie die Details für Ihren Einkauf an.</p>
    </div>

    <!-- Formular Card -->
    <div class="card p-8 sm:p-10 border border-gray-100">
        <form asp-action="ArtikelBearbeiten" method="post" class="space-y-6">
            <input type="hidden" asp-for="Id" />
            
            <div class="input-group">
                <label asp-for="Name" class="label-standard">Artikelname</label>
                <div class="relative rounded-xl shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <fa-icon name="cart-shopping" class="input-icon" />
                    </div>
                    <input asp-for="Name" class="input-field" placeholder="z.B. Vollmilch 3.5%" required />
                </div>
            </div>

            <div class="input-group">
                <label asp-for="Anzahl" class="label-standard">Anzahl</label>
                <div class="relative rounded-xl shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <fa-icon name="hashtag" class="input-icon" />
                    </div>
                    <input asp-for="Anzahl" type="number" min="1" class="input-field" required />
                </div>
            </div>

            <div class="input-group">
                <label asp-for="Geschaeft" class="label-standard">Geschäft</label>
                <div class="relative rounded-xl shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <fa-icon name="store" class="input-icon" />
                    </div>
                    <input asp-for="Geschaeft" class="input-field" placeholder="z.B. Edeka" required />
                </div>
            </div>

            <div class="pt-6 flex flex-col sm:flex-row gap-4 border-t border-gray-100">
                <button type="submit" class="btn-primary">
                    <fa-icon name="check" class="btn-icon" />
                    Änderungen speichern
                </button>
                <a asp-action="ArtikelAnsehen" class="btn-secondary">
                    <fa-icon name="xmark" class="btn-icon-secondary" />
                    Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>
