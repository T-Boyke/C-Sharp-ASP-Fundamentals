@using _04_ShoppingList.Models
@inject IShoppingListRepository Repository
@{
    ViewData["Title"] = "Erfolgreich Angelegt";
    var repoCount = Repository.Positions.Count();
}

<div class="success-container">
    <!-- Success Icon Container with Animation -->
    <div class="success-icon-bg animate-success-pop">
        <i class="fa-regular fa-circle-check text-5xl text-green-600 animate-check" aria-hidden="true"></i>
    </div>
    
    <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 mb-4">Artikel gespeichert!</h1>
    
    <p class="text-xl text-gray-600 mb-8">
        Ihre Liste wächst. Aktuell befinden sich <span class="count-badge">@repoCount</span> Artikel auf Ihrer Einkaufsliste.
    </p>

    <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a asp-action="ArtikelForm" class="btn-primary">
            <i class="fa-solid fa-plus w-5 h-5 mr-2"></i>
            Weitere Artikel anlegen
        </a>
        <a asp-action="Index" class="btn-secondary">
            <i class="fa-solid fa-arrow-left w-5 h-5 mr-2 text-gray-500"></i>
            Zurück zur Startseite
        </a>
    </div>
</div>

