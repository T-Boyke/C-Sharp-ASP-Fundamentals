@*
 * ==========================================
 * IHK-Dokumentation: Tailwind CSS OOCSS Module
 * ==========================================
 * Datei: _TailwindStyles.cshtml
 * Zweck: Zentrale Definition der Corporate Design Farben, Layout-Container 
 *        und Button-Komponenten nach OOCSS/Atomic-Prinzip.
 * Architektur-Hinweis: Da das Tailwind v4 Browser CDN externe CSS-Dateien 
 *        via Netzwerkanfrage blockieren kann, werden die CSS-Module hier 
 *        als Razor Partial View abstrahiert und sicher inline geladen. 
 *        Die Separation of Concerns (Trennung von HTML und CSS Logik) 
 *        bleibt dadurch IHK-konform erhalten.
 * ==========================================
 *@

<style type="text/tailwindcss">
    /* --- 1. THEME MODULE (theme.css) --- */
    @theme {
        /* Primäre Markenfarbe (Professionelles Ocean Blue statt KI-Purple) */
        --color-brand-100: #dbeafe;
        --color-brand-400: #60a5fa;
        --color-brand-500: #3b82f6; /* Hauptfarbe */
        --color-brand-600: #2563eb; /* Hover */
        --color-brand-700: #1d4ed8;
        --color-brand-800: #1e40af;
    }

    /* --- 2. BUTTON MODULE (buttons.css) --- */
    /* Basis-Klasse für alle Buttons (Struktur, Spacing, Transitions) */
    @utility btn {
        @apply inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 transition-all duration-300 cursor-pointer;
    }

    /* Primärer Button (z.B. für Hauptaktionen wie "Speichern") */
    @utility btn-primary {
        @apply bg-brand-500 text-white hover:bg-brand-600 focus:ring-brand-500 hover:shadow-lg hover:-translate-y-0.5;
    }

    /* Sekundärer Button (z.B. für "Zurück"-Aktionen) */
    @utility btn-secondary {
        @apply bg-white text-gray-700 border-gray-300 border hover:bg-gray-50 focus:ring-brand-500 hover:shadow-md hover:-translate-y-0.5;
    }

    /* --- 3. LAYOUT MODULE (layout.css) --- */
    /* 
     * UI-Card: Container für Formulare und Listen. Verwendet transparenten Hintergrund 
     * mit Blur-Effekt (Glassmorphismus) für ein Premium-Design. 
     */
    @utility card {
        @apply bg-white/80 backdrop-blur-xl rounded-2xl shadow-xl border border-white/20 p-8;
    }

    /* 
     * Input-Feld: Einheitliches Design für Texteingaben und Number-Inputs. 
     * Beinhaltet Hover/Focus-States zur Verbesserung der UX.
     */
    @utility input-field {
        @apply mt-1 block w-full rounded-xl border-gray-300 shadow-sm focus:border-brand-500 focus:ring-brand-500 sm:text-sm px-4 py-3 bg-white/50 transition-all duration-200 outline-none;
    }
</style>
