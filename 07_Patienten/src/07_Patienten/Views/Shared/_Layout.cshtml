<!DOCTYPE html>
<html lang="de" class="h-full bg-slate-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedCare Patientenverwaltung</title>
    
    <!-- CSS Dependencies -->
    <script src="https://unpkg.com/@@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="~/lib/fortawesome/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_07_Patienten.styles.css" asp-append-version="true" />

    <style type="text/tailwindcss">
        @@theme {
            --color-primary: #0ea5e9;
            --color-primary-dark: #0284c7;
            --color-secondary: #64748b;
        }

        @@utility glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        @@layer base {
            body { @@apply text-slate-900 antialiased h-full; }
            h1, h2, h3 { @@apply font-bold tracking-tight; }
        }

        @@layer components {
            .nav-link {
                @@apply flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200 text-slate-600 hover:bg-white hover:text-primary hover:shadow-sm;
            }
            .nav-link.active {
                @@apply bg-white text-primary shadow-sm;
            }
            .btn-premium {
                @@apply inline-flex items-center justify-center gap-2 px-6 py-2.5 rounded-xl font-semibold transition-all duration-300 transform active:scale-95 shadow-md hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2;
            }
        }
    </style>
</head>
<body class="flex flex-col">
    <header class="sticky top-0 z-50 glass border-b border-slate-200" role="banner">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Hauptnavigation">
            <div class="flex justify-between h-20 items-center">
                <div class="flex items-center gap-8">
                    <a asp-controller="Patients" asp-action="Index" class="text-2xl font-black text-slate-900 flex items-center gap-2 group" aria-label="MedCare Startseite">
                        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg group-hover:rotate-12 transition-transform duration-300" aria-hidden="true">
                            <i class="fa-solid fa-hospital-user"></i>
                        </div>
                        <span class="hidden sm:inline">Med<span class="text-primary tracking-tighter">Care</span></span>
                    </a>

                    <div class="hidden md:flex items-center gap-2" role="menubar">
                        <a class="nav-link" asp-controller="Patients" asp-action="Index" role="menuitem">
                            <i class="fa-solid fa-users" aria-hidden="true"></i> Patienten
                        </a>
                        <a class="nav-link" asp-controller="Patients" asp-action="Create" role="menuitem">
                            <i class="fa-solid fa-user-plus" aria-hidden="true"></i> Neuaufnahme
                        </a>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <div class="hidden lg:flex items-center gap-2 text-xs font-semibold text-slate-400 uppercase tracking-widest bg-slate-100/50 px-3 py-1 rounded-full border border-slate-200" aria-live="polite">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true"></span>
                        Praxis Online
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow py-12" role="main">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-white border-t border-slate-200 py-12 mt-auto" role="contentinfo">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col md:flex-row justify-between items-center gap-8 text-slate-500 text-sm">
                <div class="flex flex-col gap-2 items-center md:items-start text-center md:text-left">
                    <div class="flex items-center gap-2 font-bold text-slate-800">
                        <i class="fa-solid fa-shield-halved text-emerald-500" aria-hidden="true"></i>
                        <span>MedCare Systems &copy; 2026</span>
                    </div>
                    <p class="text-xs">Built with ❤️ & copious amounts of Energy-Drinks by <b>Tobias Boyke</b></p>
                </div>

                <nav class="flex flex-wrap justify-center gap-x-8 gap-y-4 font-medium uppercase tracking-wider text-[10px]" aria-label="Rechtliche Informationen">
                    <a asp-controller="Home" asp-action="Privacy" class="hover:text-primary transition-colors flex items-center gap-1.5" aria-label="Datenschutzerklärung einsehen">
                        <i class="fa-solid fa-lock text-slate-300" aria-hidden="true"></i> Datenschutz
                    </a>
                    <a asp-controller="Home" asp-action="Imprint" class="hover:text-primary transition-colors flex items-center gap-1.5" aria-label="Impressum einsehen">
                        <i class="fa-solid fa-file-contract text-slate-300" aria-hidden="true"></i> Impressum
                    </a>
                    <a asp-controller="Home" asp-action="Support" class="hover:text-primary transition-colors flex items-center gap-1.5" aria-label="Hilfe und Support erhalten">
                        <i class="fa-solid fa-circle-question text-slate-300" aria-hidden="true"></i> Support-Center
                    </a>
                </nav>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
