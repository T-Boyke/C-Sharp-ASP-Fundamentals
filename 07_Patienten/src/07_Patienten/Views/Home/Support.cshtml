@{
    ViewData["Title"] = "Support";
}
<div class="glass p-12 rounded-3xl animate-fade-in text-center">
    <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6 text-primary">
        <i class="fa-solid fa-headset text-4xl"></i>
    </div>
    <h1 class="text-4xl text-slate-900 mb-4">Brauchen Sie Hilfe?</h1>
    <p class="text-slate-500 max-w-lg mx-auto mb-10">Unser Support-Team ist rund um die Uhr für Sie da, um technische Fragen zur Patientenverwaltung zu klären.</p>

    <div class="flex flex-wrap justify-center gap-4">
        <a href="mailto:support@@medcare.example.com" class="btn-premium bg-primary text-white hover:bg-primary-dark">
            <i class="fa-solid fa-envelope"></i> E-Mail schreiben
        </a>
        <a href="#" class="btn-premium bg-slate-100 text-slate-700 hover:bg-slate-200">
            <i class="fa-solid fa-book"></i> Dokumentation
        </a>
    </div>
</div>
