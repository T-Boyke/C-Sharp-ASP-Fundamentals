@model _07_Patienten.Domain.Entities.Patient

@{
    ViewData["Title"] = "Akte schließen";
}

<div class="max-w-xl mx-auto animate-fade-in mt-12">
    <div class="glass rounded-3xl p-10 bg-white/40 shadow-2xl border border-rose-100 text-center">
        <div class="w-20 h-20 bg-rose-50 rounded-full flex items-center justify-center text-rose-500 text-3xl mx-auto mb-6 shadow-sm">
            <i class="fa-solid fa-user-slash"></i>
        </div>
        
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Patient löschen?</h1>
        <p class="text-slate-500 mb-8 leading-relaxed">
            Sind Sie sicher, dass Sie die Akte von <span class="font-bold text-slate-900">@Model.Fullname</span> dauerhaft löschen möchten?<br />
            <span class="text-rose-500 text-xs font-bold uppercase tracking-widest bg-rose-50 px-2 py-1 rounded mt-2 inline-block italic">
                Achtung: Alle Behandlungsdaten werden ebenfalls gelöscht!
            </span>
        </p>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="flex flex-col gap-3">
                <button type="submit" class="btn-premium bg-rose-500 text-white hover:bg-rose-600 w-full py-4 text-lg">
                    <i class="fa-solid fa-trash-can"></i> Unwiderruflich löschen
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-premium bg-slate-100 text-slate-600 hover:bg-slate-200 w-full py-3">
                    Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>
