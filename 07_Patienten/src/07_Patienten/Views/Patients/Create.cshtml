@model _07_Patienten.Domain.Entities.Patient

@{
    ViewData["Title"] = "Neuaufnahme";
}

<div class="max-w-2xl mx-auto animate-fade-in">
    <div class="flex items-center gap-4 mb-8">
        <a asp-action="Index" class="text-slate-400 hover:text-primary transition-colors">
            <i class="fa-solid fa-chevron-left"></i> Zurück
        </a>
        <h1 class="text-3xl font-bold text-slate-900">Patientenaufnahme</h1>
    </div>

    <div class="glass rounded-3xl p-10 bg-white/40 shadow-xl border border-white">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-rose-50 text-rose-600 rounded-xl text-sm italic"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="Firstname" class="text-sm font-semibold text-slate-700 ml-1">Vorname</label>
                    <div class="relative">
                        <i class="fa-solid fa-user absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm"></i>
                        <input asp-for="Firstname" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="z.B. Max" />
                    </div>
                    <span asp-validation-for="Firstname" class="text-xs text-rose-500 ml-1"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Lastname" class="text-sm font-semibold text-slate-700 ml-1">Nachname</label>
                    <div class="relative">
                        <i class="fa-solid fa-user-tag absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm"></i>
                        <input asp-for="Lastname" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="z.B. Mustermann" />
                    </div>
                    <span asp-validation-for="Lastname" class="text-xs text-rose-500 ml-1"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Birthdate" class="text-sm font-semibold text-slate-700 ml-1">Geburtsdatum</label>
                    <div class="relative">
                        <i class="fa-solid fa-calendar absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm"></i>
                        <input asp-for="Birthdate" type="date" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                    </div>
                    <span asp-validation-for="Birthdate" class="text-xs text-rose-500 ml-1"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="SocialSecurityNumber" class="text-sm font-semibold text-slate-700 ml-1">SVNR (10-stellig)</label>
                    <div class="relative">
                        <i class="fa-solid fa-id-card absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm" aria-hidden="true"></i>
                        <input asp-for="SocialSecurityNumber" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="1234010180" aria-required="true" />
                    </div>
                    <span asp-validation-for="SocialSecurityNumber" class="text-xs text-rose-500 ml-1"></span>
                </div>

                <div class="space-y-2 md:col-span-2">
                    <label asp-for="NextAppointmentDate" class="text-sm font-semibold text-slate-700 ml-1">Nächster Termin (Optional)</label>
                    <div class="relative">
                        <i class="fa-solid fa-calendar-check absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm" aria-hidden="true"></i>
                        <input asp-for="NextAppointmentDate" type="datetime-local" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                    </div>
                    <span asp-validation-for="NextAppointmentDate" class="text-xs text-rose-500 ml-1"></span>
                </div>

                <div class="space-y-2 md:col-span-2">
                    <label asp-for="Symptoms" class="text-sm font-semibold text-slate-700 ml-1">Symptome / Anamnese</label>
                    <div class="relative">
                        <textarea asp-for="Symptoms" rows="3" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="Aktuelle Beschwerden dokumentieren..."></textarea>
                    </div>
                    <span asp-validation-for="Symptoms" class="text-xs text-rose-500 ml-1"></span>
                </div>

                <div class="md:col-span-2 flex items-center gap-3 p-4 bg-amber-50 rounded-2xl border border-amber-100">
                    <div class="flex items-center h-5">
                        <input asp-for="IsPrivatePatient" type="checkbox" class="w-5 h-5 text-primary border-amber-300 rounded focus:ring-primary/20 cursor-pointer" />
                    </div>
                    <div class="text-sm">
                        <label asp-for="IsPrivatePatient" class="font-bold text-amber-900 cursor-pointer">Privatpatient (Priorität)</label>
                        <p class="text-amber-700/70 text-xs">Aktiviert erweiterte Abrechnungsoptionen und Priorisierung.</p>
                    </div>
                </div>
            </div>

            <!-- 3NF: Arzt & Krankenkasse -->
            <h3 class="text-lg font-bold text-slate-900 mt-10 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-stethoscope text-primary"></i> Zuordnung
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label asp-for="DoctorId" class="text-sm font-semibold text-slate-700 ml-1">Behandelnder Arzt</label>
                    <div class="relative">
                        <i class="fa-solid fa-user-doctor absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm"></i>
                        <select asp-for="DoctorId" asp-items="ViewBag.Doctors" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none">
                            <option value="">-- Arzt wählen --</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-2">
                    <label asp-for="HealthInsuranceId" class="text-sm font-semibold text-slate-700 ml-1">Krankenkasse</label>
                    <div class="relative">
                        <i class="fa-solid fa-shield-heart absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm"></i>
                        <select asp-for="HealthInsuranceId" asp-items="ViewBag.HealthInsurances" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none">
                            <option value="">-- Kasse wählen --</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- 3NF: Anschrift -->
            <h3 class="text-lg font-bold text-slate-900 mt-10 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-location-dot text-primary"></i> Anschrift
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div class="space-y-2 md:col-span-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">Straße</label>
                    <input name="Address.Street" value="" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="z.B. Königsallee" />
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">Hausnr.</label>
                    <input name="Address.HouseNumber" value="" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="42a" />
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">PLZ</label>
                    <input name="Address.ZipCode" value="" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="40212" />
                </div>
                <div class="space-y-2 md:col-span-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">Stadt</label>
                    <input name="Address.City" value="" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 px-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="Düsseldorf" />
                </div>
            </div>

            <!-- 3NF: Kontakt -->
            <h3 class="text-lg font-bold text-slate-900 mt-10 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-address-book text-primary"></i> Kontakt
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">    
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">Telefon</label>
                    <div class="relative">
                        <i class="fa-solid fa-phone absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm"></i>
                        <input name="ContactInfo.PhoneNumber" value="" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="0211 1234567" />
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700 ml-1">E-Mail</label>
                    <div class="relative">
                        <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-sm"></i>
                        <input name="ContactInfo.Email" type="email" value="" class="w-full bg-white/60 border border-slate-200 rounded-xl py-3 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="max@example.de" />
                    </div>
                </div>
            </div>

            <div class="mt-10 flex gap-4">
                <button type="submit" class="flex-grow btn-premium bg-primary text-white hover:bg-primary-dark" aria-label="Patientenakte anlegen">
                    <i class="fa-solid fa-save" aria-hidden="true"></i> Patient Speichern
                </button>
                <a asp-action="Index" class="btn-premium bg-slate-100 text-slate-600 hover:bg-slate-200" aria-label="Abbrechen und zurück zur Liste">
                    Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>
