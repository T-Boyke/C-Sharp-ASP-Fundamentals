@model _06_NewsApplication2.Domain.Entities.Author

@{
    ViewData["Title"] = "Autor bearbeiten";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-10 text-center">
        <div class="inline-flex w-16 h-16 bg-blue-100 text-blue-600 items-center justify-center rounded-full text-2xl mb-4">
            <i class="fa-solid fa-user-gear"></i>
        </div>
        <h1 class="text-3xl font-black text-slate-900">Profildaten anpassen</h1>
        <p class="text-slate-500 mt-2">Aktualisiere die Informationen für @Model.Fullname.</p>
    </div>

    <form asp-action="Edit" class="card space-y-6">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm p-4 bg-red-50 rounded-lg"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
                <label asp-for="Firstname" class="block text-sm font-bold text-slate-700">Vorname</label>
                <input asp-for="Firstname" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none" />
                <span asp-validation-for="Firstname" class="text-red-500 text-xs mt-1"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Lastname" class="block text-sm font-bold text-slate-700">Nachname</label>
                <input asp-for="Lastname" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-blue-100 focus:border-blue-500 transition-all outline-none" />
                <span asp-validation-for="Lastname" class="text-red-500 text-xs mt-1"></span>
            </div>
        </div>

        <div class="pt-6 flex items-center justify-between">
            <a asp-action="Index" class="text-slate-500 hover:text-slate-700 font-medium">Abbrechen</a>
            <button type="submit" class="btn-primary bg-slate-900 hover:bg-black">
                <i class="fa-solid fa-check-double"></i> Aktualisieren
            </button>
        </div>
    </form>
</div>
