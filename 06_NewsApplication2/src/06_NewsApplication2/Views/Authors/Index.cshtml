@model IEnumerable<_06_NewsApplication2.Domain.Entities.Author>

@{
    ViewData["Title"] = "Unsere Autoren";
}

<div class="space-y-10">
    <div class="flex justify-between items-end">
        <div>
            <h1 class="text-4xl font-extrabold text-slate-900">Autorenverwaltung</h1>
            <p class="text-slate-500 mt-2">Verwalte die Redaktion der NewsApplication2.</p>
        </div>
        <a asp-action="Create" class="btn-primary">
            <i class="fa-solid fa-user-plus"></i> Neuer Autor
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        @foreach (var item in Model)
        {
            <div class="card flex flex-col items-center text-center group">
                <div class="w-20 h-20 rounded-full bg-slate-100 flex items-center justify-center text-3xl text-slate-400 group-hover:bg-blue-600 group-hover:text-white transition-all mb-4">
                    <i class="fa-solid fa-user-graduate"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-900">@item.Fullname</h3>
                <p class="text-sm text-slate-500 mb-6">@item.Articles.Count Artikel veröffentlicht</p>
                
                <div class="flex gap-2 w-full pt-4 border-t border-slate-100">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="flex-1 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-50 rounded-lg transition-colors">
                        <i class="fa-solid fa-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="flex-1 py-2 text-sm font-semibold text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                        <i class="fa-solid fa-trash-can"></i>
                    </a>
                </div>
            </div>
        }
    </div>
</div>
