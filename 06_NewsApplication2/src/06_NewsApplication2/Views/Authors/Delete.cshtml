@model _06_NewsApplication2.Domain.Entities.Author

@{
    ViewData["Title"] = "Autor löschen";
}

<div class="max-w-2xl mx-auto">
    <div class="card border-red-200 bg-red-50/30">
        <div class="text-center mb-8">
            <div class="inline-flex w-16 h-16 bg-red-100 text-red-600 items-center justify-center rounded-full text-2xl mb-4">
                <i class="fa-solid fa-user-slash"></i>
            </div>
            <h1 class="text-3xl font-black text-slate-900">Autor unwiderruflich löschen?</h1>
            <p class="text-red-600/70 mt-4 font-medium px-8 leading-relaxed">
                Bist du sicher, dass du <span class="font-bold text-red-700 underline">@Model.Fullname</span> entfernen möchtest? 
                Alle verknüpften Artikel werden ebenfalls gelöscht (Kaskadierendes Löschen).
            </p>
        </div>

        <div class="bg-white rounded-xl p-6 border border-red-100 mb-8 flex items-center gap-4">
            <i class="fa-solid fa-circle-exclamation text-3xl text-red-500"></i>
            <div class="text-sm">
                <p class="font-bold text-slate-900 underline uppercase">Achtung</p>
                <p class="text-slate-600">Diese Aktion kann nicht rückgängig gemacht werden!</p>
            </div>
        </div>

        <form asp-action="Delete" class="flex items-center justify-center gap-4">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="px-6 py-3 text-slate-600 hover:text-slate-900 font-bold transition-colors">Abbrechen</a>
            <button type="submit" class="px-8 py-3 bg-red-600 text-white rounded-xl font-black shadow-lg shadow-red-200 hover:bg-red-700 transition-all active:scale-95 flex items-center gap-2">
                <i class="fa-solid fa-trash-can"></i> JETZT LÖSCHEN
            </button>
        </form>
    </div>
</div>
